{% extends 'base.html.twig' %}

{% block title %}Mon Avis Pro— Gérez vos avis Google en 5 minutes par semaine
{% endblock %}

{% block body %}
	<div class="rr-landing-hero">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-12 col-lg-8 text-center">

					<h1 class="rr-landing-title mb-3">
						Gérez votre réputation Google<br class="d-none d-md-inline">
						en 5 minutes par semaine
					</h1>

					<p class="rr-landing-sub mx-auto">
						MonAvisPro centralise vos avis Google, vous alerte instantanément en cas d'avis défavorable et propose des réponses générées par IA, modifiables à votre guise. Une approche maîtrisée de votre e-réputation.
					</p>

					<div class="d-flex flex-wrap gap-2 justify-content-center mb-3">
						<a href="{{ path('demo_login') }}" class="rr-btn rr-btn-cta rr-btn-lg">
							Tester la démo en 1 clic
						</a>
						{% if not app_demo_mode %}
							<a href="{{ path('app_register') }}" class="rr-btn rr-btn-secondary rr-btn-lg">
								Créer un compte
							</a>
						{% endif %}
					</div>

					{# Métriques #}
					<div class="row g-3 justify-content-center">
						<div class="col-6 col-md-4">
							<div class="rr-card text-center">
								<div class="rr-stat-val rr-green">88%</div>
								<div class="rr-stat-label">Des clients font confiance aux avis Google</div>
							</div>
						</div>
						<div class="col-6 col-md-4">
							<div class="rr-card text-center">
								<div class="rr-stat-val rr-yellow">30s</div>
								<div class="rr-stat-label">Pour répondre à un avis avec l'Intelligence Artificielle</div>
							</div>
						</div>
						<div class="col-6 col-md-4">
							<div class="rr-card text-center">
								<div class="rr-stat-val rr-purple">IA</div>
								<div class="rr-stat-label">Analyse thématique & réponses contextualisées</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	{# Features section #}
	<section id="features" style="position:relative;z-index:1;padding:48px 0">
		<div class="container">
			<div class="text-center mb-5">
				<h2 style="font-size:28px;font-weight:800;color:#fff;letter-spacing:-.5px;margin-bottom:10px">
					Détectez, comprenez, répondez. Trois étapes essentielles, regroupées dans un outil unique.
				</h2>
				<p style="font-size:14px;color:rgba(255,255,255,.45);max-width:400px;margin:0 auto">
					Un seul outil pour surveiller, analyser et répondre à vos avis Google.
				</p>
			</div>

			<div class="row g-3">
				<div class="col-12 col-md-6 col-lg-4">
					<div class="rr-card h-100">
						<div class="rr-pill rr-pill-red mb-3">Alertes temps réel</div>
						<div style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px">Soyez informé immédiatement</div>
						<div style="font-size:13px;color:rgba(255,255,255,.45);line-height:1.6">
							Notification email instantanée à chaque nouvel avis négatif. Vous intervenez avant que l'impact ne se propage à votre note globale.
						</div>
					</div>
				</div>
				<div class="col-12 col-md-6 col-lg-4">
					<div class="rr-card h-100">
						<div class="rr-pill rr-pill-green mb-3">Analyse intelligente</div>
						<div style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px">Comprenez vos clients en un coup d'œil</div>
						<div style="font-size:13px;color:rgba(255,255,255,.45);line-height:1.6">
							L'IA analyse l'ensemble de vos avis et fait ressortir les points forts récurrents et les axes d'amélioration prioritaires.
						</div>
					</div>
				</div>
				<div class="col-12 col-md-6 col-lg-4">
					<div class="rr-card h-100">
						<div class="rr-pill rr-pill-purple mb-3">Réponses générées par IA</div>
						<div style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px">Répondez avec le ton juste, à chaque fois</div>
						<div style="font-size:13px;color:rgba(255,255,255,.45);line-height:1.6">
							L'IA rédige une réponse personnalisée pour chaque avis. Choisissez le ton, ajustez si besoin, validez. Pro et rapide.
						</div>
					</div>
				</div>
			</div>

			{# CTA final #}
			<div class="text-center mt-5">
				<a href="{{ path('demo_login') }}" class="rr-btn rr-btn-cta rr-btn-lg">
					Voir la démo en action
				</a>
				<div class="mt-3" style="font-size:12px;color:rgba(255,255,255,.3)">
					Gratuit · Sans engagement · Résultat immédiat
				</div>
			</div>
		</div>
	</section>
{% endblock %}
