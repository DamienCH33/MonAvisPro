{% extends 'base.html.twig' %}

{% block title %}Mon Avis Pro— Gérez vos avis Google en 5 minutes par semaine{% endblock %}

{% block body %}
<div class="rr-landing-hero">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8 text-center">

        <div class="rr-announcement mb-3">
          Nouveau · Analyse IA des avis Google
        </div>

        <h1 class="rr-landing-title mb-3">
          Gérez votre réputation Google<br class="d-none d-md-inline">
          en 5 minutes par semaine
        </h1>

        <p class="rr-landing-sub mx-auto">
          Mon Avis Pro surveille vos avis Google, vous alerte dès qu'un avis négatif tombe,
          et génère une réponse professionnelle en un clic grâce à l'IA ou par vous même si vous le souhaitez.
        </p>

        <div class="d-flex flex-wrap gap-2 justify-content-center mb-5">
          {% if not app_demo_mode %}
            <a href="{{ path('app_register') }}" class="rr-btn rr-btn-cta rr-btn-lg">
              Démarrer gratuitement
            </a>
          {% endif %}
          <a href="#features" class="rr-btn rr-btn-secondary rr-btn-lg">
            Voir comment ça marche
          </a>
        </div>

        {# Métriques #}
        <div class="row g-3 justify-content-center">
          <div class="col-6 col-md-4">
            <div class="rr-card text-center">
              <div class="rr-stat-val rr-green">4.6★</div>
              <div class="rr-stat-label">Note moyenne clients</div>
            </div>
          </div>
          <div class="col-6 col-md-4">
            <div class="rr-card text-center">
              <div class="rr-stat-val rr-white">2 min</div>
              <div class="rr-stat-label">Pour répondre à un avis</div>
            </div>
          </div>
          <div class="col-6 col-md-4">
            <div class="rr-card text-center">
              <div class="rr-stat-val rr-purple">IA</div>
              <div class="rr-stat-label">Analyse thématique</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

{# Features section #}
<section id="features" style="position:relative;z-index:1;padding:48px 0">
  <div class="container">
    <div class="text-center mb-5">
      <h2 style="font-size:28px;font-weight:800;color:#fff;letter-spacing:-.5px;margin-bottom:10px">
        Tout ce dont vous avez besoin
      </h2>
      <p style="font-size:14px;color:rgba(255,255,255,.45);max-width:400px;margin:0 auto">
        Un seul outil pour surveiller, analyser et répondre à vos avis Google.
      </p>
    </div>

    <div class="row g-3">
      <div class="col-12 col-md-6 col-lg-4">
        <div class="rr-card h-100">
          <div class="rr-pill rr-pill-red mb-3">Alertes immédiates</div>
          <div style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px">Ne ratez plus rien</div>
          <div style="font-size:13px;color:rgba(255,255,255,.45);line-height:1.6">
            Email instantané dès qu'un avis négatif est publié. Réagissez avant que ça se propage.
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="rr-card h-100">
          <div class="rr-pill rr-pill-green mb-3">Analyse IA</div>
          <div style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px">Comprenez vos clients</div>
          <div style="font-size:13px;color:rgba(255,255,255,.45);line-height:1.6">
            L'IA identifie les thèmes récurrents dans vos avis et vous suggère des actions concrètes.
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="rr-card h-100">
          <div class="rr-pill rr-pill-purple mb-3">Réponses IA</div>
          <div style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px">Répondez en 1 clic</div>
          <div style="font-size:13px;color:rgba(255,255,255,.45);line-height:1.6">
            Générez une réponse professionnelle et personnalisée. Choisissez le ton, copiez, c'est envoyé.
          </div>
        </div>
      </div>
    </div>

    {# CTA final #}
    <div class="text-center mt-5">
      <a href="" class="rr-btn rr-btn-cta rr-btn-lg">
        Commencer — 3 analyses gratuites
      </a>
      <div class="mt-3" style="font-size:12px;color:rgba(255,255,255,.3)">
        Sans carte bancaire · Annulable à tout moment
      </div>
    </div>
  </div>
</section>
{% endblock %}