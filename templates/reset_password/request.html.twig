{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié — MonAvisPro{% endblock %}

{% block public_nav %}
<div class="d-flex align-items-center gap-2">
    <span style="font-size:12px;color:rgba(255,255,255,.4)">Déjà un compte ?</span>
    <a href="{{ path('app_login') }}" class="rr-btn rr-btn-secondary rr-btn-sm">Connexion</a>
</div>
{% endblock %}

{% block body %}
<div class="rr-auth-wrapper">
    <div class="rr-auth-box">

        <div class="rr-logo mb-4 justify-content-center">
            <div class="rr-logo__dot"></div>
            <span class="rr-logo__text">MonAvisPro</span>
        </div>

        <div class="rr-auth-title text-center">Mot de passe oublié</div>
        <div class="rr-auth-sub text-center">
            Entrez votre email, nous vous enverrons un lien pour réinitialiser votre mot de passe.
        </div>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="rr-flash rr-flash-error">{{ flash_error }}</div>
        {% endfor %}

        {{ form_start(requestForm, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="mb-4">
            {{ form_label(requestForm.email, 'Email', {'label_attr': {'class': 'rr-label'}}) }}
            {{ form_widget(requestForm.email, {'attr': {'class': 'rr-input', 'placeholder': 'vous@exemple.fr'}}) }}
            {% if form_errors(requestForm.email) %}
                <div class="rr-error">{{ form_errors(requestForm.email) }}</div>
            {% endif %}
        </div>

        <button type="submit" class="rr-btn rr-btn-primary rr-btn-full rr-btn-lg">
            Envoyer le lien de réinitialisation
        </button>

        {{ form_end(requestForm) }}

        <div class="text-center mt-4" style="font-size:12px;color:rgba(255,255,255,.35)">
            <a href="{{ path('app_login') }}" style="color:var(--rr-green)">← Retour à la connexion</a>
        </div>

    </div>
</div>
{% endblock %}