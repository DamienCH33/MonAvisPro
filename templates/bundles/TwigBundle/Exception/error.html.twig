<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Erreur {{ status_code }} — MonAvisPro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: "DM Sans", system-ui, sans-serif;
            background: #0a0e1a;
            color: rgba(255,255,255,0.9);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .aurora {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 280px;
            background: linear-gradient(135deg, rgba(83,74,183,0.45), rgba(29,158,117,0.35), rgba(87,212,255,0.2));
            pointer-events: none;
            opacity: 0.55;
        }
        .container {
            text-align: center;
            position: relative;
            z-index: 1;
            padding: 32px 16px;
        }
        .code {
            font-size: 96px;
            font-weight: 800;
            letter-spacing: -4px;
            background: linear-gradient(135deg, #534ab7, #5dcaa5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
            margin-bottom: 16px;
        }
        .title {
            font-size: 22px;
            font-weight: 700;
            color: rgba(255,255,255,0.9);
            margin-bottom: 8px;
        }
        .sub {
            font-size: 14px;
            color: rgba(255,255,255,0.4);
            margin-bottom: 32px;
            line-height: 1.6;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 24px;
            background: linear-gradient(135deg, #534ab7, #1d9e75);
            color: #fff;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: opacity 0.2s;
        }
        .btn:hover { opacity: 0.85; }
        .logo {
            display: flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
            margin-bottom: 40px;
            text-decoration: none;
        }
        .logo-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: linear-gradient(135deg, #534ab7, #5dcaa5);
        }
        .logo-text {
            font-size: 16px;
            font-weight: 800;
            color: rgba(255,255,255,0.9);
        }
    </style>
</head>
<body>
    <div class="aurora"></div>
    <div class="container">
        <a href="/" class="logo">
            <div class="logo-dot"></div>
            <span class="logo-text">MonAvisPro</span>
        </a>
        <div class="code">{{ status_code }}</div>
        <div class="title">
            {% if status_code == 404 %}
                Page introuvable
            {% elseif status_code == 403 %}
                Accès refusé
            {% elseif status_code == 500 %}
                Erreur serveur
            {% else %}
                Une erreur est survenue
            {% endif %}
        </div>
        <div class="sub">
            {% if status_code == 404 %}
                La page que vous cherchez n'existe pas ou a été déplacée.
            {% elseif status_code == 403 %}
                Vous n'avez pas les droits pour accéder à cette ressource.
            {% elseif status_code == 500 %}
                Une erreur interne s'est produite. Nos équipes sont prévenues.
            {% else %}
                Quelque chose s'est mal passé. Revenez dans quelques instants.
            {% endif %}
        </div>
        <a href="/" class="btn">← Retour à l'accueil</a>
    </div>
</body>
</html>