{% extends 'base.html.twig' %}

{% block title %}Avis —
	{{ current_establishment.name }}
{% endblock %}
{% block page_title %}Tous les avis
{% endblock %}

{% block topbar_actions %}
	<select class="rr-select" id="filter-rating" onchange="loadReviews()">
		<option value="">Toutes les notes</option>
		<option value="5">★★★★★ 5</option>
		<option value="4">★★★★☆ 4</option>
		<option value="3">★★★☆☆ 3</option>
		<option value="2">★★☆☆☆ 2</option>
		<option value="1">★☆☆☆☆ 1</option>
	</select>

	<select class="rr-select" id="filter-period" onchange="loadReviews()">
		<option value="all">Toute période</option>
		<option value="7j">7 derniers jours</option>
		<option value="30j">30 derniers jours</option>
		<option value="90j">90 derniers jours</option>
	</select>
{% endblock %}

{% block body %}
	<div id="reviews-container">
		<div class="rr-empty">Chargement des avis…</div>
	</div>

	<div class="d-flex justify-content-between align-items-center mt-4" id="pagination-container" style="display:none!important"></div>
{% endblock %}

{% block modals %}
	<div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content" style="background:#0f1224;border:1px solid rgba(255,255,255,.1);border-radius:16px">
				<div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,.08)">
					<h5 class="modal-title" style="color:#fff;font-size:15px;font-weight:700">
						Générer une réponse IA
					</h5>
					<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
				</div>

				<div class="modal-body p-4">
					<div class="mb-3">
						<label class="rr-label">Ton de la réponse</label>
						<div class="rr-tabs">
							<button type="button" class="rr-tab active" onclick="setTone('cordial', this)">Cordial</button>
							<button type="button" class="rr-tab" onclick="setTone('formel', this)">Formel</button>
							<button type="button" class="rr-tab" onclick="setTone('empathique', this)">Empathique</button>
						</div>
					</div>

					<div id="reply-result" style="display:none">
						<label class="rr-label">Réponse générée</label>
						<div class="rr-textarea" id="reply-text" style="min-height:100px;font-size:13px;line-height:1.6;color:var(--rr-t2)"></div>
						<button type="button" onclick="copyReply()" class="rr-btn rr-btn-primary rr-btn-sm mt-2">
							Copier la réponse
						</button>
					</div>

					<div class="mt-3">
						<label class="rr-label">Ou écrire votre réponse</label>
						<textarea id="manual-reply" class="rr-textarea" style="min-height:120px" placeholder="Écrivez votre réponse au client..."></textarea>
					</div>

					<div id="reply-loading" style="display:none;text-align:center;padding:20px;color:var(--rr-t3);font-size:13px">
						Génération en cours…
					</div>
				</div>

				<div class="modal-footer" style="border-top:1px solid rgba(255,255,255,.08)">
					<button type="button" class="rr-btn rr-btn-secondary rr-btn-sm" data-bs-dismiss="modal">Fermer</button>
					<button type="button" class="rr-btn rr-btn-primary rr-btn-sm" onclick="generateReply()" id="generate-btn">Générer</button>
					<button type="button" class="rr-btn rr-btn-primary rr-btn-sm" onclick="publishReply()" id="publish-btn" style="display:none;">Publier</button>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	<script src="{{ asset('js/reviews.js') }}"></script>
{% endblock %}
